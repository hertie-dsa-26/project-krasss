import pandas as pd
from pathlib import Path

# paths to import files
RAW_DATA_DIR = Path(__file__).parent.parent.parent / "data" / "weather_data_raw"
MSA_KEY_PATH = Path(__file__).parent.parent.parent / "data" / "MSA_data_key_clean.csv"

# columns to keep from imported weather data files
KEEP_COLUMNS = ["DATE", "LATITUDE", "LONGITUDE", "NAME", "CLDD", "DT00", "DT32",
                "DX32", "DX70", "DX90", "EMNT", "EMXT", "HTDD", "PRCP", "TAVG",
                "TMAX", "TMIN", "TSUN"]

# function to import all weather data files in bulk
def combine_csvs(raw_dir: Path = RAW_DATA_DIR) -> pd.DataFrame:
    csv_files = list(raw_dir.glob("*.csv"))

    if not csv_files:
        raise FileNotFoundError(f"No CSV files found in: {raw_dir}")

    print(f"Found {len(csv_files)} CSV files.")

    dataframes = []
    for filepath in csv_files:
        print(f"Loading: {filepath.name}")
        df = pd.read_csv(filepath)
        df["source_file"] = filepath.name
        dataframes.append(df)

    combined_df = pd.concat(dataframes, ignore_index=True)
    combined_df = combined_df[[col for col in KEEP_COLUMNS if col in combined_df.columns]]
    print(f"Combined dataset shape: {combined_df.shape}")

    return combined_df


# read in all weather data files using the function
weather = combine_csvs()

# filter for required years
weather_filtered = weather[weather['DATE'].between(2012, 2023)]

# import msa_key_data
msa_key_df = pd.read_csv(MSA_KEY_PATH)

# join weather data with msa data
weather_merged = weather_filtered.merge(msa_key_df, left_on="NAME", right_on="weather_station", how="left")

# drop unnecessary columns after joining with msa data
weather_merged = weather_merged.iloc[:, :-3]

# export merged file as csv
weather_merged.to_csv("../../data/weather_data_combined.csv", index=False)